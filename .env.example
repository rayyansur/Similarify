# ── Spotify OAuth ────────────────────────────────────────────────────────────
# Create an app at https://developer.spotify.com/dashboard
# and add http://127.0.0.1:8000/auth/callback as a Redirect URI.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/auth/callback

# ── Auth ─────────────────────────────────────────────────────────────────────
# Any long random string, e.g.: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@127.0.0.1:5432/similarify

# ── Frontend (Next.js) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=   # same value as SPOTIFY_CLIENT_ID above
FRONTEND_URL=http://127.0.0.1:3000
